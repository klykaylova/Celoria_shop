<!DOCTYPE html>
<html>
<head>
  <title>Admin Panel</title>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "admin/admin_base", media: "all" %>
  <%= stylesheet_link_tag "admin/admin_navbar", media: "all" %>
  <%= javascript_importmap_tags %>
</head>

<body>

  <!-- СВІТЛЕ МЕНЮ АДМІН-ПАНЕЛІ -->
  <nav class="admin-navbar">

    <!-- Ліва частина -->
    <div class="admin-nav-left">
      <%= link_to root_path, class: "admin-logo-link" do %>
        ← На сайт
      <% end %>
    </div>

    <!-- Права частина -->
    <div class="admin-nav-right">
      <span class="admin-user-label">
        👤 <strong><%= current_user.name %></strong>
      </span>

      <%= link_to "Вийти",
            logout_path,
            method: :delete,
            data: { turbo_method: :delete },
            class: "admin-btn-outline admin-logout-btn" %>
    </div>

  </nav>

  <!-- Контент адмінки -->
  <div class="admin-container">
    <%= yield %>
  </div>

</body>
</html>