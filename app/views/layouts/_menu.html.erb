<nav class="main-navbar">
  <div class="nav-left">
    <%= link_to "🏠 Головна", root_path, class: "nav-link" %>
    <%= link_to "👜 Каталог", products_path, class: "nav-link" %>
    <%= link_to "🛒 Кошик", cart_path, class: "nav-link" %>
    <%= link_to "📜 Замовлення", orders_path, class: "nav-link" %>
    <%= link_to "📞 Контакти", contacts_path, class: "nav-link" %>
    <%= link_to "ℹ️ Про нас", about_path, class: "nav-link" %>
  </div>

  <div class="nav-right">

    <% if logged_in? %>
      <%= link_to "👤 Профіль", profile_path, class: "nav-link nav-profile" %>

      <span class="nav-user">
        <%= current_user.name.presence || current_user.email %>
      </span>

      <% if current_user.admin? %>
        <%= link_to "⚙️ Адмін-панель", admin_dashboard_path, class: "nav-link nav-admin" %>
        <%= link_to "📦 Товари", admin_products_path, class: "nav-link nav-admin" %>
        <%= link_to "👥 Користувачі", admin_users_path, class: "nav-link nav-admin" %>
      <% end %>

      <%= button_to "🚪 Вийти",
            logout_path,
            method: :delete,
            class: "nav-link nav-logout",
            form: { class: "logout-form" } %>

    <% else %>
      <%= link_to "🔑 Вхід", login_path, class: "nav-link" %>
      <%= link_to "📝 Реєстрація", new_user_path, class: "nav-link nav-register" %>
    <% end %>

  </div>
</nav>

<hr>