<%= stylesheet_link_tag "admin/admin_products", media: "all" %>

<div class="admin-products-page">

  <%= link_to "← Повернутись назад", admin_dashboard_path, class: "back-btn" %>

  <h1 class="admin-products-title">Керування товарами</h1>

  <div class="top-actions">
    <%= link_to "➕ Додати товар", new_admin_product_path, class: "add-product-btn" %>
  </div>

  <div class="admin-products-table-wrapper">
    <table class="admin-products-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Назва</th>
          <th>Ціна</th>
          <th class="actions-header">Дії</th>
        </tr>
      </thead>

      <tbody>
        <% @products.each do |product| %>
          <tr>
            <td><%= product.id %></td>

            <td class="product-name-cell"><%= product.name %></td>

            <td><%= number_to_currency(product.price, unit: "₴") %></td>

            <td class="actions-col">
              <%= link_to "✏️ Редагувати",
                    edit_admin_product_path(product),
                    class: "table-btn edit-btn" %>

              <%= link_to "🗑 Видалити",
                    admin_product_path(product),
                    data: { turbo_method: :delete, turbo_confirm: "Видалити товар?" },
                    class: "table-btn delete-btn" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>