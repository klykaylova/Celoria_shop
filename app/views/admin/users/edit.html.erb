<%= stylesheet_link_tag "admin/admin_users", media: "all" %>

<div class="admin-users-page">

  <div class="admin-users-header">
    <%= link_to "← Назад", admin_users_path, class: "admin-back-link" %>
    <h1 class="admin-title">Редагування користувача</h1>
  </div>

  <div class="admin-form-card">

    <%= form_with model: [:admin, @user], local: true do |f| %>

      <div class="form-group">
        <label>Ім’я</label>
        <%= f.text_field :name, class: "form-input" %>
      </div>

      <div class="form-group">
        <label>Email</label>
        <%= f.email_field :email, class: "form-input" %>
      </div>

      <div class="form-group">
        <label>Роль</label>
        <%= f.select :role,
              [["Admin", "admin"], ["User", "user"], ["Guest", "guest"]],
              {},
              class: "form-input" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Зберегти", class: "admin-btn" %>
      </div>

    <% end %>

  </div>

</div>