<%= stylesheet_link_tag "contacts", media: "all" %>

<div class="contact-page">

  <h1 class="contact-title">📩 Контакти</h1>

  <p class="contact-subtitle">
    Ми будемо раді почути ваші відгуки, запитання або пропозиції.
  </p>

  <% if flash[:notice] %>
    <div class="contact-alert success"><%= flash[:notice] %></div>
  <% end %>

  <% if flash[:alert] %>
    <div class="contact-alert error"><%= flash[:alert] %></div>
  <% end %>

  <div class="contact-card">

    <%= form_with model: @feedback,
                  url: contacts_path,
                  local: true,
                  class: "contact-form" do |f| %>

      <div class="form-group">
        <label class="contact-label">Ваше ім'я</label>
        <%= f.text_field :name,
              class: "contact-input",
              placeholder: "Введіть ваше ім'я" %>
      </div>

      <div class="form-group">
        <label class="contact-label">Email</label>
        <%= f.email_field :email,
              class: "contact-input",
              placeholder: "example@gmail.com" %>
      </div>

      <div class="form-group">
        <label class="contact-label">Повідомлення</label>
        <%= f.text_area :message,
              rows: 5,
              class: "contact-textarea",
              placeholder: "Введіть ваше повідомлення..." %>
      </div>

      <%= f.submit "Надіслати", class: "contact-submit-btn" %>

    <% end %>

  </div>
</div>