<h1>💳 Оплата замовлення №<%= @order.id %></h1>

<p><strong>Сума до сплати:</strong> <%= number_to_currency(@order.total, unit: "₴") %></p>

<%= form_with model: [@order, @payment], local: true do |form| %>
  <div>
    <%= form.label :payment_type, "Оберіть спосіб оплати:" %><br>
    <%= form.select :payment_type, [["💳 Карткою", "карткою"], ["💵 При отриманні", "при отриманні"]], prompt: "Виберіть..." %>
  </div>

  <br>

  <%= form.submit "✅ Підтвердити оплату", style: "background-color:#28a745;color:white;padding:10px 15px;border:none;border-radius:5px;cursor:pointer;" %>
<% end %>

<hr>

<%= link_to "⬅️ Назад до замовлення", @order, style: "text-decoration:none;color:#007bff;" %>
