<%= stylesheet_link_tag "orders", media: "all" %>

<div class="checkout-page">

  <!-- ЛІВА КОЛОНКА — ФОРМА -->
  <div class="checkout-form">

    <h1 class="checkout-title">Оформлення замовлення</h1>

    <%= form_with model: @order, url: orders_path, local: true, id: "orderForm" do |f| %>

      <!-- Контактні дані -->
      <div class="form-group">
        <%= f.label :name, "Ваше ім'я" %>
        <%= f.text_field :name, class: "form-control", required: true %>
      </div>

      <div class="form-group">
        <%= f.label :phone, "Телефон" %>
        <%= f.telephone_field :phone, class: "form-control", required: true %>
      </div>

      <!-- Спосіб доставки -->
      <div class="form-group">
        <%= f.label :delivery_method, "Доставка" %>
        <%= f.select :delivery_method,
              [["Нова Пошта", "nova_poshta"],
               ["Укрпошта", "ukrposhta"],
               ["Кур’єр", "courier"]],
              {}, class: "form-control", id: "deliverySelect" %>
      </div>

      <!-- Адреса -->
      <div class="form-group" id="addressField">
        <%= f.label :address, "Адреса доставки" %>
        <%= f.text_field :address, class: "form-control",
              placeholder: "Місто, вулиця, будинок" %>
      </div>

      <!-- Поштовий індекс -->
      <div class="form-group" id="postcodeField" style="display:none;">
        <%= f.label :postcode, "Поштовий індекс" %>
        <%= f.number_field :postcode, class: "form-control" %>
      </div>

      <!-- Спосіб оплати -->
      <div class="form-group">
        <%= f.label :payment_method, "Оплата" %>
        <%= f.select :payment_method,
              [["Оплата карткою", "card"],
               ["Післяплата", "cash_on_delivery"]],
              {}, class: "form-control" %>
      </div>

      <%= f.submit "Підтвердити замовлення", class: "checkout-submit" %>

    <% end %>
  </div>

  <!-- ПРАВА КОЛОНКА — ПІДСУМОК -->
  <div class="checkout-summary">

    <h2>Ваше замовлення</h2>

    <% @cart_items.each do |item| %>
      <div class="summary-item">

        <div class="summary-img-box">
          <% if item[:product].images.attached? %>
            <%= image_tag item[:product].images.first,
                  class: "summary-img" %>
          <% else %>
            <img src="/placeholder.png" class="summary-img">
          <% end %>
        </div>

        <div class="summary-info">
          <p class="summary-name"><%= item[:product].name %></p>
          <p class="summary-qty">Кількість: <%= item[:quantity] %></p>
          <p class="summary-price">
            ₴<%= number_with_precision(item[:product].price * item[:quantity], precision: 0) %>
          </p>
        </div>

      </div>
    <% end %>

    <hr>

    <div class="summary-total">
      Разом:
      <span>₴<%= number_with_precision(@cart_items.sum { |i| i[:product].price * i[:quantity] }, precision: 0) %></span>
    </div>

  </div>
</div>